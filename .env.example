# GitHub OAuth 配置
# 用于 Web 端 GitHub OAuth 登录
# 获取方式：https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Better Auth 基础 URL（可选）
# 用于生成 OAuth 回调地址，默认：http://localhost:3000
# BETTER_AUTH_URL=http://localhost:3000

# HTTP 代理配置（可选）
# 如果 Node.js 访问 GitHub API 失败（ECONNRESET），配置代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 数据库配置（可选）
# 默认使用 SQLite，数据库文件位于 ./hexo-cms.db
# DATABASE_URL=file:./hexo-cms.db

# 日志级别（可选）
# 可选值：debug, info, warn, error
# 默认：info
# LOG_LEVEL=info

# 开发环境配置（可选）
# NODE_ENV=development
# PORT=3000
